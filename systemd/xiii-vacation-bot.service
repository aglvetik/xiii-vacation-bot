[Unit]
Description=XIII Vacation Discord Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/XIII/xiii-vacation-bot
EnvironmentFile=/opt/XIII/xiii-vacation-bot/.env
ExecStart=/opt/XIII/xiii-vacation-bot/xiii-vacation-bot
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
